# ════════════════════════════════════════════════════════════════════
#  LumeFlow ↔ Sankhya Integration Service — Configuração
#  Copie este arquivo para .env e preencha os valores
# ════════════════════════════════════════════════════════════════════

# ── Servidor ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
LOG_LEVEL=info
CORS_ORIGIN=https://seu-lumeflow.base44.app

# ── Sankhya — URL base ────────────────────────────────────────────
# Cloud:   https://api.sankhya.com.br
# On-prem: https://sankhya.suaempresa.com.br
SANKHYA_BASE_URL=https://api.sankhya.com.br

# ── Sankhya — Credenciais OAuth2 (Sankhya.ID / API Gateway) ──────
# Geradas em: portal.sankhya.com.br > Aplicativos > Novo Aplicativo
SANKHYA_CLIENT_ID=seu_client_id
SANKHYA_CLIENT_SECRET=seu_client_secret

# X-Token: token de autenticação do aplicativo (header "token")
SANKHYA_X_TOKEN=seu_x_token

# App Key (opcional, mas recomendado para identificar o app nas requisições)
SANKHYA_APP_KEY=

# ── Sankhya — Usuário operador ────────────────────────────────────
# Crie um usuário dedicado com permissões mínimas de leitura/escrita
SANKHYA_USERNAME=usuario_integracao
SANKHYA_PASSWORD=senha_segura

# ── Parâmetros de negócio Sankhya ────────────────────────────────
# CODTIPOPER do Pedido de Venda aprovado pelo comercial
# Verifique: Sankhya > Arquivo > Tipos de Operação > Pedido de Venda
SANKHYA_TIPO_OPER_VENDA=1110

# Status "aprovado/liberado" no campo STATUSNOTA
# 'L' = Liberado (padrão na maioria das instalações Sankhya)
SANKHYA_STATUS_APROVADO=L

# Código do local de estoque da fábrica (CODLOCAL)
SANKHYA_LOCAL_ESTOQUE=1

# CODTIPOPER para criação de ordens de fabricação (PCP)
SANKHYA_TIPO_OPER_FABRICACAO=2210

# Timeout das requisições (ms)
SANKHYA_TIMEOUT=30000

# ── Base44 / LumeFlow ─────────────────────────────────────────────
BASE44_APP_ID=seu_app_id
BASE44_API_TOKEN=seu_api_token
BASE44_BASE_URL=https://api.base44.com

# ── Sincronização automática (cron) ──────────────────────────────
# Formato cron: minuto hora dia mês dia_semana
# https://crontab.guru para testar expressões

# Pull Sankhya → LumeFlow (buscar pedidos aprovados) — padrão: 5min
SYNC_PULL_CRON=*/5 * * * *

# Push LumeFlow → Sankhya (enviar ordens de produção) — padrão: 10min
SYNC_PUSH_CRON=*/10 * * * *

# Janela de busca: quantos dias atrás buscar no Sankhya
SYNC_WINDOW_DAYS=30

# ── Segurança ────────────────────────────────────────────────────
# Chave para validar webhooks recebidos do Base44/LumeFlow (HMAC-SHA256)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=troque_por_valor_aleatorio_seguro
